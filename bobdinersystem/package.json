{
  "name": "aesamonte-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "next-dev": "cd frontend && npm run dev",
    "flask-server": "py backend/app.py",
    "dev": "concurrently -n \"NEXT,FLASK\" -c \"cyan,yellow\" \"npm run next-dev\" \"npm run flask-server\"",
    "build": "cd frontend && npm install && npm run build",
    "start": "cd frontend && npm run start",
    "lint": "eslint"
  },
  "dependencies": {
    "@vercel/speed-insights": "^1.0.4",
    "axios": "^1.16.1",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
